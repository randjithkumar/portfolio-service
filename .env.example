# Application
SERVER_PORT=8081

# PostgreSQL
POSTGRES_DB=pe_portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

DB_URL=jdbc:postgresql://postgres:5432/pe_portfolio_db
DB_USERNAME=postgres
DB_PASSWORD=root
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2

# JWT
JWT_SECRET=U0ZWeE1XMHlaR2xtYVc0MFpXNW9kR05zYldGa05tVjA
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=portfolio-audit-group
KAFKA_HEALTH_ENABLED=false

# Outbox
OUTBOX_POLL_DELAY_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_SEND_TIMEOUT_SECONDS=10

# JVM
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC

# Kafka reliability and scaling
KAFKA_ENABLED=true
KAFKA_HEALTH_ENABLED=true
KAFKA_TOPIC_PARTITIONS=3
KAFKA_REPLICATION_FACTOR=1
KAFKA_CONSUMER_CONCURRENCY=3
KAFKA_RETRY_ATTEMPTS=4
KAFKA_RETRY_DELAY_MS=2000
KAFKA_RETRY_MULTIPLIER=2.0
KAFKA_RETRY_MAX_DELAY_MS=10000
OUTBOX_ENABLED=true