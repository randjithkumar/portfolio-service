# Application
SERVER_PORT=8081
APP_IMAGE_TAG=0.0.1

#Repo
APP_GIT_CONTEXT=git@github.com:randjithkumar/portfolio-service.git#main

# PostgreSQL
POSTGRES_DB=pe_portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2

# Flyway
SPRING_FLYWAY_ENABLED=true
FLYWAY_REPAIR_ENABLED=false

# JWT
# Use a Base64-encoded secret containing at least 32 random bytes.
JWT_SECRET=U0ZWeE1XMHlaR2xtYVc0MFpXNW9kR05zYldGa05tVjA
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=portfolio-audit-group
KAFKA_HEALTH_ENABLED=false
KAFKA_EXTERNAL_HOST=localhost
KAFKA_EXTERNAL_PORT=9092

# Outbox
OUTBOX_ENABLED=false
OUTBOX_POLL_DELAY_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_SEND_TIMEOUT_SECONDS=10

# Market data — primary provider
FMP_MARKET_DATA_BASE_URL=https://financialmodelingprep.com
MARKET_DATA_API_KEY=wjyJI7aDchB1egIdItUsolr7JoTVBdrm
FMP_CONNECT_TIMEOUT=3s
FMP_READ_TIMEOUT=5s

# Market data — secondary provider
YAHOO_MARKET_DATA_BASE_URL=https://query1.finance.yahoo.com
YAHOO_CONNECT_TIMEOUT=3s
YAHOO_READ_TIMEOUT=5s

# JVM
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError
